# ─── Application ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="DevTalent"

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/devtalent?schema=public"

# ─── Authentication (NextAuth v5 / Auth.js) ──────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
AUTH_URL=http://localhost:3000

# Google OAuth (optional)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="notifications@devtalent.io"
RESEND_FROM_NAME="DevTalent"

# ─── File Upload (UploadThing) ───────────────────────────────────────────────
UPLOADTHING_SECRET="sk_live_your_uploadthing_secret"
UPLOADTHING_APP_ID="your_uploadthing_app_id"

# ─── Admin ───────────────────────────────────────────────────────────────────
# Used during seeding to create the initial admin account
ADMIN_EMAIL="admin@devtalent.io"
ADMIN_PASSWORD="change-this-in-production"
